#: kmimetypefinder.cpp:26
#, kde-format
msgid "MIME Type Finder"
msgstr "MIME تۈرىنى ئىزدىگۈچ"

#: kmimetypefinder.cpp:27
#, kde-format
msgid "Gives the MIME type for a given file"
msgstr "بەلگىلەنگەن ھۆججەتكە MIME تۈرىنى كۆرسىتىدۇ"

#: kmimetypefinder.cpp:33
#, kde-format
msgid "Use only the file content for determining the MIME type."
msgstr "پەقەت ھۆججەت مەزمۇنى ئارقىلىق MIME تۈرىنى جەزملەيدۇ."

#: kmimetypefinder.cpp:35
#, kde-format
msgid ""
"Whether use the file name only for determining the MIME type. Not used if -c "
"is specified."
msgstr ""
"ھۆججەت ئاتى ئارقىلىق MIME تۈرىنى جەزملەمدۇ يوق. ئەگەر ‪«-c»‬ بەلگىلەنگەن بولسا "
"ياق."

#: kmimetypefinder.cpp:36
#, kde-format
msgid "The filename to test. '-' to read from stdin."
msgstr ""
"سىناشتا ئىشلىتىدىغان ھۆججەت ئاتى. ‹-› بولسا ئۆلچەملىك كىرگۈزۈش (stdin) "
"ئوقۇيدۇ."
